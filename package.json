{
  "name": "wordzoo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 8000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:migrate": "npx tsx lib/db/migrate.ts",
    "db:seed": "npx tsx lib/db/seed.ts",
    "db:import": "npx tsx data/import.ts",
    "db:seed-mnemonics": "npx tsx lib/db/seed-mnemonics.ts",
    "db:seed-audio": "npx tsx lib/db/seed-audio.ts",
    "db:seed-dialogues": "npx tsx lib/db/seed-dialogues.ts",
    "db:seed-phrase-mnemonics": "npx tsx lib/db/seed-phrase-mnemonics.ts",
    "db:seed-expanded": "npx tsx lib/db/seed-expanded.ts",
    "db:seed-phrase-images-auto": "npx tsx lib/db/seed-phrase-images-auto.ts",
    "db:seed-missing-images": "npx tsx lib/db/seed-missing-images.ts",
    "db:seed-orphan-mnemonics": "npx tsx lib/db/seed-orphan-mnemonics.ts",
    "db:seed-scene-anchors": "npx tsx lib/db/seed-scene-anchors.ts",
    "db:recompress-blob-images": "npx tsx lib/db/recompress-blob-images.ts",
    "db:cleanup-orphan-blobs": "npx tsx lib/db/cleanup-orphan-blobs.ts",
    "db:backfill-images": "npm run db:seed-orphan-mnemonics -- --limit=500 && npm run db:seed-missing-images -- --type=all --limit=500 && npm run db:seed-scene-anchors -- --limit=100"
  },
  "dependencies": {
    "@auth/neon-adapter": "^1.11.1",
    "@google/genai": "^1.44.0",
    "@neondatabase/serverless": "^1.0.2",
    "@vercel/blob": "^2.3.1",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.35.1",
    "html2canvas": "^1.4.1",
    "idb": "^8.0.3",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sonner": "^2.0.7",
    "stripe": "^20.4.1",
    "uuid": "^13.0.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
