# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# claude code
.claude/settings.local.json
MEMORY.md
.mcp.json
.playwright-mcp/
.superpowers/

# screenshots
*.png

# brand assets — keep these tracked despite the global *.png ignore above
!public/brand/*.png
!public/icons/*.png
!app/icon.png
!app/apple-icon.png
!app/opengraph-image.png

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.worktrees/

# local-only image archive (originals from generateImage during backfill)
/backups/
